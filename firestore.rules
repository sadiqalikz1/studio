rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Default: Deny everything unless specified
    match /{document=**} {
      allow read, write: if false;
    }

    // Branches: Authenticated users can list/read
    match /branches/{branchId} {
      allow read: if isAuthenticated();
      // Admin only for write (to be refined later if needed)
      allow write: if isAuthenticated(); 
    }

    // Suppliers: Authenticated users can read
    match /suppliers/{supplierId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Invoices: Authenticated users can read/write their branch data
    match /invoices/{invoiceId} {
      allow read, write: if isAuthenticated();
    }

    // Payments: Authenticated users can read/write
    match /payments/{paymentId} {
      allow read, write: if isAuthenticated();
    }

    // Users: Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // User Settings: Private per user
    match /userSettings/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // System Settings: Admin only
    match /systemSettings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Helper to check if the user is an admin
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }
  }
}
