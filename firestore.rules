rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the user is an admin
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    // Default: Deny everything unless specified
    match /{document=**} {
      allow read, write: if false;
    }

    // Branches: Authenticated users can list/read
    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); 
    }

    // Suppliers: Authenticated users can read/write
    match /suppliers/{supplierId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Invoices: Authenticated users can read/write
    match /invoices/{invoiceId} {
      allow read, write: if isAuthenticated();
    }

    // Payments: Authenticated users can read/write
    match /payments/{paymentId} {
      allow read, write: if isAuthenticated();
    }

    // Debit Notes: Authenticated users can read/write (collection and documents)
    match /debitNotes {
      allow read: if isAuthenticated();
      match /{debitNoteId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Credit Notes: Authenticated users can read/write (collection and documents)
    match /creditNotes {
      allow read: if isAuthenticated();
      match /{creditNoteId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Invoice Allocations (FIFO tracking)
    match /invoiceAllocations/{allocationId} {
      allow read, write: if isAuthenticated();
    }

    // Users: Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // User Settings: Private per user
    match /userSettings/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Mapping Presets: Users can manage their own presets
    match /mappingPresets/{presetId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.createdBy == request.auth.uid || resource.data.isPublic == true);
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    // Upload History: Log of all import sessions
    match /uploadHistory/{historyId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Admin & Team Roles
    match /adminUsers/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /financeTeamUsers/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // System Settings: Admin only
    match /systemSettings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
